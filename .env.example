# load to env and fill in the values before running docker 

# PostgreSQL 
POSTGRES_DB=linkEdge
POSTGRES_USER=linkEdge
POSTGRES_PASSWORD=changeme

# Mosquitto MQTT (leave blank for anonymous access in development)
MQTT_USERNAME=
MQTT_PASSWORD=

# ChirpStack publishes decoded uplinks here; '+' wildcards match any application/device
MQTT_UPLINK_TOPIC=application/+/device/+/event/up

# Hub — change HUB_SECRET_KEY before exposing to the network
HUB_SECRET_KEY=change-me-in-production
EXPORT_BATCH_SIZE=50
EXPORT_RETRY_INTERVAL=30

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
