# ── PostgreSQL / TimescaleDB ────────────────────────────────────────────────
POSTGRES_DB=linkEdge
POSTGRES_USER=linkEdge
POSTGRES_PASSWORD=changeme

# ── Mosquitto MQTT ──────────────────────────────────────────────────────────
# Leave blank for anonymous access (development only)
MQTT_USERNAME=
MQTT_PASSWORD=

# ChirpStack publishes decoded uplinks here; '+' wildcards match any application/device
MQTT_UPLINK_TOPIC=application/+/device/+/event/up

# ── Hub ─────────────────────────────────────────────────────────────────────
# Secret for signing internal tokens — change before exposing to the network
HUB_SECRET_KEY=change-me-in-production

# How many pending readings to flush per export cycle
EXPORT_BATCH_SIZE=50

# Seconds between buffered-export retry passes
EXPORT_RETRY_INTERVAL=30

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
